{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "voice-pipeline-backend",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["src.voice_pipeline.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8000
    },
    {
      "name": "monitor-api",
      "runtimeExecutable": "uvicorn",
