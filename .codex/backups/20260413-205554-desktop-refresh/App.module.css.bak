.appRoot {
  display: flex;
  height: 100vh;
  width: 100vw;
  background: var(--surface-command-bg);
  color: var(--text-primary);
  font-family: var(--font-body);
  overflow: hidden;
  letter-spacing: -0.01em;
  transition: background-color var(--transition-normal), box-shadow var(--transition-normal);
}

.appRoot[data-section="history"] {
  background: var(--surface-monitor-bg);
}

.appRoot[data-phase="idle"] {
  --phase-surface-bg: var(--phase-idle-bg);
}

.appRoot[data-phase="listening"] {
  --phase-surface-bg: var(--phase-listening-bg);
}

.appRoot[data-phase="processing"] {
  --phase-surface-bg: var(--phase-processing-bg);
}

.appRoot[data-phase="loop"] {
  --phase-surface-bg: var(--phase-loop-bg);
}

.appRoot[data-phase="verify"] {
  --phase-surface-bg: var(--phase-verify-bg);
}

.appRoot[data-phase="error"] {
  --phase-surface-bg: var(--phase-error-bg);
}

.appRoot[data-phase="done"] {
  --phase-surface-bg: var(--phase-done-bg);
}

.dragRegion {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 48px;
  -webkit-app-region: drag;
  z-index: 9999;
  pointer-events: none;
}

/* Global Reset enhancements */
:global(*) {
  box-sizing: border-box;
}

:global(::-webkit-scrollbar) {
  width: 10px;
  background: transparent;
}

:global(::-webkit-scrollbar-thumb) {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 5px;
  border: 2px solid #0b0c0f;
}

:global(::-webkit-scrollbar-thumb:hover) {
  background: rgba(255, 255, 255, 0.2);
}
