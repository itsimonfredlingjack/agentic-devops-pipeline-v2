.workspace {
  flex: 1;
  display: flex;
  flex-direction: column;
  position: relative;
  background: var(--surface-command-bg);
  z-index: 1;
  overflow: hidden;
  min-height: 0;
}

.workspace[data-surface="history"] {
  background: var(--surface-monitor-bg);
}

.canvas {
  flex: 1;
  min-height: 0;
  display: grid;
  grid-template-columns: minmax(340px, 0.95fr) minmax(420px, 1.25fr);
  gap: 20px;
  padding: 0 20px 20px;
}

.primaryColumn,
.secondaryColumn {
  min-height: 0;
}

.primaryColumn {
  display: flex;
}

.secondaryColumn {
  overflow: hidden;
}

@media (max-width: 1180px) {
  .canvas {
    grid-template-columns: 1fr;
    overflow-y: auto;
  }

  .primaryColumn,
  .secondaryColumn {
    min-height: auto;
  }
}
