.sidebar {
  width: 276px;
  background: #0d1016;
  border-right: 1px solid rgba(255, 255, 255, 0.06);
  display: flex;
  flex-direction: column;
  user-select: none;
  flex-shrink: 0;
  z-index: 10;
  transition: width var(--motion-context);
  overflow: hidden;
}

.sidebarCollapsed {
  width: 72px;
}

.macSpacer {
  height: 48px;
  flex-shrink: 0;
}

.orgHeader {
  padding: 10px 20px 22px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.sidebarCollapsed .orgHeader {
  justify-content: center;
  padding-inline: 0;
}

.orgLogomark {
  width: 14px;
  height: 14px;
  background: linear-gradient(135deg, #16a34a, #0f766e);
  border-radius: 4px;
  border: none;
  padding: 0;
  cursor: pointer;
  box-shadow: 0 0 10px rgba(22, 163, 74, 0.18);
}

.orgLogomark:focus-visible {
  outline: 2px solid rgba(34, 197, 94, 0.6);
  outline-offset: 3px;
}

.orgTitle {
  font-size: 13px;
  font-weight: 600;
  color: #f8fafc;
  letter-spacing: 0.01em;
  white-space: nowrap;
}

.globalModeSwitcher,
.viewSwitcher {
  margin: 0 16px 18px;
  display: flex;
  gap: 6px;
  padding: 4px;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.modeBtn,
.viewBtn {
  flex: 1;
  border: none;
  background: transparent;
  color: #8d97aa;
  border-radius: 9px;
  cursor: pointer;
  transition:
    background-color var(--motion-fast),
    color var(--motion-fast),
    box-shadow var(--motion-fast);
}

.modeBtn {
  padding: 10px 0;
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.08em;
}

.viewBtn {
  padding: 8px 0;
  font-family: var(--font-mono);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.05em;
}

.modeBtnActive,
.viewBtnActive {
  background: rgba(255, 255, 255, 0.08);
  color: #f8fafc;
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.05);
}

.navSection {
  padding: 0 16px 22px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.navSection:last-child {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding-bottom: 16px;
}

.sectionTitle {
  margin: 0;
  padding: 0 8px;
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 600;
  color: #6f7787;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.telemetryItem {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 6px 8px;
  color: #b5becf;
  font-size: 13px;
}

.sidebarCollapsed .telemetryItem {
  justify-content: center;
}

.dot {
  width: 7px;
  height: 7px;
  border-radius: 999px;
  background-color: #475569;
  transition:
    background-color var(--motion-context),
    box-shadow var(--motion-context);
}

.dotVoiceOn {
  background-color: #38bdf8;
  box-shadow: 0 0 8px rgba(56, 189, 248, 0.35);
}

.dotMonitorOn {
  background-color: #818cf8;
  box-shadow: 0 0 8px rgba(129, 140, 248, 0.35);
}

.queueList {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.emptyQueue,
.historyHint {
  padding: 14px 12px;
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.06);
  background: rgba(255, 255, 255, 0.02);
  font-size: 12px;
  color: #95a0b5;
  line-height: 1.5;
}

.emptyQueue strong,
.emptyQueue span,
.historyHint strong,
.historyHint span {
  display: block;
}

.emptyQueue span,
.historyHint span {
  margin-top: 4px;
}

.queueItem {
  width: 100%;
  padding: 12px;
  border-radius: 12px;
  cursor: pointer;
  transition:
    background-color var(--motion-fast),
    border-color var(--motion-fast),
    box-shadow var(--motion-fast);
  display: flex;
  flex-direction: column;
  gap: 8px;
  text-align: left;
  font: inherit;
  color: inherit;
  border: 1px solid rgba(255, 255, 255, 0);
  background: transparent;
  overflow: hidden;
}

.sidebarCollapsed .queueItem {
  padding: 12px 0;
  align-items: center;
}

.queueItem:hover {
  background: rgba(255, 255, 255, 0.03);
}

.queueItem:focus-visible {
  outline: 2px solid rgba(56, 189, 248, 0.55);
  outline-offset: 1px;
}

.activeQueueItem {
  background: rgba(56, 189, 248, 0.08);
  border-color: rgba(56, 189, 248, 0.18);
  box-shadow: inset 0 0 0 1px rgba(56, 189, 248, 0.12);
}

.issueTopRow {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.sidebarCollapsed .issueTopRow {
  justify-content: center;
}

.issueMetaLeft,
.issueMetaRight,
.issueFooter {
  display: flex;
  align-items: center;
  gap: 8px;
}

.issueFooter {
  justify-content: space-between;
  color: #8d97aa;
  font-size: 11px;
}

.statusLabel,
.assigneeLabel {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.iconStandard {
  color: #8d97aa;
}

.iconUrgent {
  color: #f97316;
}

.qId {
  font-family: var(--font-mono);
  font-size: 11px;
  color: #d7deeb;
  font-weight: 500;
}

.qTitle {
  font-size: 13px;
  color: #eff6ff;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-weight: 500;
}

@media (prefers-reduced-motion: reduce) {
  .sidebar,
  .modeBtn,
  .viewBtn,
  .queueItem,
  .dot {
    transition: none;
  }
}
