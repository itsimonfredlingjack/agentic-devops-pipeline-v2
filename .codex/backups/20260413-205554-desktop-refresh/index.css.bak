:root {
  color-scheme: dark;

  /* Canvas */
  --canvas-bg: #111118;
  --phase-surface-bg: radial-gradient(circle at 50% 50%, rgba(142, 142, 147, 0.04) 0%, transparent 58%);

  /* Visual voice surfaces */
  --surface-command-bg: #0a0b10;
  --surface-command-panel: rgba(255, 255, 255, 0.07);
  --surface-command-panel-strong: rgba(20, 20, 30, 0.9);
  --surface-command-border: rgba(255, 255, 255, 0.12);
  --surface-command-glow: rgba(96, 165, 250, 0.2);
  --surface-monitor-bg: #0b0c0f;
  --surface-monitor-panel: rgba(255, 255, 255, 0.03);
  --surface-monitor-panel-strong: rgba(12, 15, 24, 0.92);
  --surface-monitor-border: rgba(255, 255, 255, 0.06);
  --surface-monitor-glow: rgba(148, 163, 184, 0.16);

  /* Glass */
  --glass-bg: rgba(255, 255, 255, 0.06);
  --glass-bg-strong: rgba(255, 255, 255, 0.08);
  --glass-bg-hover: rgba(255, 255, 255, 0.10);
  --glass-bg-subtle: rgba(255, 255, 255, 0.04);
  --glass-border: rgba(255, 255, 255, 0.10);
  --glass-border-hover: rgba(255, 255, 255, 0.18);
  --glass-highlight: rgba(255, 255, 255, 0.07);
  --glass-blur: 20px;
  --glass-blur-strong: 30px;
  --glass-radius: 16px;
  --glass-radius-lg: 20px;

  /* Typography */
  --font-body: 'Inter', system-ui, sans-serif;
  --font-mono: 'JetBrains Mono', monospace;
  --type-display-size: 32px;
  --type-display-line: 1.16;
  --type-section-size: 14px;
  --type-section-line: 1.36;
  --type-body-size: 13px;
  --type-body-line: 1.5;
  --type-meta-size: 11px;
  --type-meta-line: 1.4;

  /* Text */
  --text-primary: rgba(255, 255, 255, 0.92);
  --text-secondary: rgba(255, 255, 255, 0.65);
  --text-tertiary: rgba(255, 255, 255, 0.50);
  --text-muted: rgba(255, 255, 255, 0.42);

  /* Phase colors */
  --phase-idle: #8e8e93;
  --phase-idle-rgb: 142, 142, 147;
  --phase-listening: #30b0c7;
  --phase-listening-rgb: 48, 176, 199;
  --phase-processing: #ff9f0a;
  --phase-processing-rgb: 255, 159, 10;
  --phase-loop: #5856d6;
  --phase-loop-rgb: 88, 86, 214;
  --phase-verify: #007aff;
  --phase-verify-rgb: 0, 122, 255;
  --phase-error: #ff375f;
  --phase-error-rgb: 255, 55, 95;
  --phase-done: #34c759;
  --phase-done-rgb: 52, 199, 89;
  --phase-idle-bg: radial-gradient(circle at 20% 20%, rgba(142, 142, 147, 0.04) 0%, transparent 56%);
  --phase-listening-bg: radial-gradient(circle at 22% 18%, rgba(48, 176, 199, 0.06) 0%, transparent 56%);
  --phase-processing-bg: radial-gradient(circle at 25% 22%, rgba(255, 159, 10, 0.06) 0%, transparent 56%);
  --phase-loop-bg: radial-gradient(circle at 24% 20%, rgba(88, 86, 214, 0.06) 0%, transparent 56%);
  --phase-verify-bg: radial-gradient(circle at 20% 20%, rgba(0, 122, 255, 0.05) 0%, transparent 56%);
  --phase-error-bg: radial-gradient(circle at 20% 20%, rgba(255, 55, 95, 0.06) 0%, transparent 56%);
  --phase-done-bg: radial-gradient(circle at 20% 20%, rgba(52, 199, 89, 0.05) 0%, transparent 56%);

  /* Semantic statuses */
  --status-success: #34c759;
  --status-success-bg: rgba(52, 199, 89, 0.12);
  --status-success-border: rgba(52, 199, 89, 0.35);
  --status-success-glow: rgba(52, 199, 89, 0.26);
  --status-danger: #ff375f;
  --status-danger-bg: rgba(255, 55, 95, 0.12);
  --status-danger-border: rgba(255, 55, 95, 0.34);
  --status-danger-glow: rgba(255, 55, 95, 0.26);
  --status-warning: #ff9f0a;
  --status-warning-bg: rgba(255, 159, 10, 0.12);
  --status-warning-border: rgba(255, 159, 10, 0.35);
  --status-warning-glow: rgba(255, 159, 10, 0.24);
  --status-info: #0a84ff;
  --status-info-bg: rgba(10, 132, 255, 0.12);
  --status-info-border: rgba(10, 132, 255, 0.35);
  --status-info-glow: rgba(10, 132, 255, 0.24);

  /* Accent */
  --accent-primary: #5856d6;
  --accent-gradient: linear-gradient(135deg, #5856d6, #af52de);

  /* Shadows — outer depth + inset highlight */
  --shadow-panel: 0 4px 24px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.07);
  --shadow-panel-hover: 0 12px 42px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.12);
  --shadow-hud: 0 16px 64px rgba(0, 0, 0, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.08);

  /* Transitions */
  --motion-fast: 140ms ease;
  --motion-context: 220ms cubic-bezier(0.4, 0, 0.2, 1);
  --transition-fast: var(--motion-fast);
  --transition-normal: var(--motion-context);
  --transition-smooth: 300ms cubic-bezier(0.4, 0, 0.2, 1);
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html, body, #root {
  height: 100%;
  background:
    var(--phase-surface-bg),
    radial-gradient(ellipse at top right, rgba(88, 86, 214, 0.08), transparent 50%),
    radial-gradient(ellipse at bottom left, rgba(48, 176, 199, 0.05), transparent 40%),
    var(--canvas-bg);
  color: var(--text-primary);
  font-family: var(--font-body);
  line-height: var(--type-body-line);
  -webkit-font-smoothing: antialiased;
}

/* Subtle noise overlay */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E") repeat;
  opacity: 0.03;
  mix-blend-mode: overlay;
  pointer-events: none;
  z-index: 9999;
}

/* Drag region for frameless window */
.drag-region {
  -webkit-app-region: drag;
}

.no-drag {
  -webkit-app-region: no-drag;
}

/* Focus styles */
:focus-visible {
  outline: 2px solid var(--accent-primary);
  outline-offset: 2px;
}

button:focus-visible {
  outline: none;
  box-shadow: 0 0 0 3px rgba(88, 86, 214, 0.4);
}

input:focus-visible {
  outline: none;
}

/* Glass panel — structural, no hover lift */
.glass-panel {
  background: var(--glass-bg);
  backdrop-filter: blur(var(--glass-blur));
  -webkit-backdrop-filter: blur(var(--glass-blur));
  box-shadow: var(--shadow-panel);
  border: 1px solid var(--glass-border);
  border-radius: var(--glass-radius);
}

/* Glass panel — interactive, with hover lift */
.glass-panel-interactive {
  background: var(--glass-bg);
  backdrop-filter: blur(var(--glass-blur));
  -webkit-backdrop-filter: blur(var(--glass-blur));
  box-shadow: var(--shadow-panel);
  border: 1px solid var(--glass-border);
  border-radius: var(--glass-radius);
  transition: box-shadow var(--transition-normal), border-color var(--transition-normal), transform var(--transition-normal);
}

.glass-panel-interactive:hover {
  box-shadow: var(--shadow-panel-hover);
  border-color: var(--glass-border-hover);
  transform: translateY(-1px);
}

.glass-panel-strong {
  background: rgba(20, 20, 30, 0.85);
  backdrop-filter: blur(var(--glass-blur-strong));
  -webkit-backdrop-filter: blur(var(--glass-blur-strong));
  box-shadow: var(--shadow-hud);
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: var(--glass-radius-lg);
}

/* Ambient phase bleed */
.phase-bleed {
  background: linear-gradient(160deg, rgba(var(--active-phase-rgb), 0.07) 0%, transparent 60%);
  box-shadow: inset 0 1px 0 rgba(var(--active-phase-rgb), 0.1);
}

/* Data pill */
.data-pill {
  font-family: var(--font-mono);
  font-size: 0.875rem;
  padding: 2px 8px;
  border-radius: 6px;
  background: rgba(255, 255, 255, 0.05);
}

/* Event row hover */
.event-row {
  background: var(--glass-bg-subtle);
  border: 1px solid rgba(255, 255, 255, 0.07);
  border-left: 2px solid transparent;
  border-radius: 12px;
  padding: 10px 14px;
  transition:
    border-color var(--transition-normal),
    border-left-color var(--transition-normal),
    background var(--transition-normal),
    box-shadow var(--transition-normal),
    transform var(--transition-normal);
}

.event-row:hover {
  border-color: rgba(var(--active-phase-rgb), 0.12);
  border-left-color: rgba(var(--active-phase-rgb), 0.5);
  background: linear-gradient(160deg, rgba(var(--active-phase-rgb), 0.06), transparent 60%);
  box-shadow: inset 0 1px 0 rgba(var(--active-phase-rgb), 0.08);
  transform: translateY(-1px);
}

/* Phase accent line */
.phase-accent::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(var(--active-phase-rgb), 0.6), transparent);
}

/* Thin scrollbars */
::-webkit-scrollbar {
  width: 4px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.12);
  border-radius: 2px;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.2);
}

@media (prefers-reduced-motion: reduce) {
  * {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}
