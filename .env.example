# SEJFA Voice Pipeline Configuration
# Copy to .env and fill in your values: cp .env.example .env

# --- Whisper / Transcription ---
WHISPER_MODEL=small
WHISPER_DEVICE=cpu                    # cpu on Mac (GPU on ai-server2)
WHISPER_BACKEND=remote                # local or remote
WHISPER_REMOTE_URL=http://100.101.182.67:8000

# --- Ollama / Intent Extraction ---
OLLAMA_URL=http://100.101.182.67:11434
OLLAMA_MODEL=qwen2.5-coder-helpful:3b
OLLAMA_TIMEOUT=120

# --- Jira Integration ---
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=DEV

# --- OpenAI Whisper Fallback (optional) ---
OPENAI_API_KEY=

# --- Ambiguity Loop ---
AMBIGUITY_THRESHOLD=0.3
MAX_CLARIFICATION_ROUNDS=3

# --- Ralph Loop Dispatch ---
AUTO_DISPATCH_LOOP=true
QUEUE_DB_PATH=loop_queue.db

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
LOG_LEVEL=INFO
